{
  "buildCommand": "cd frontend && npm install && npm run build && cp -r dist ../public",
  "outputDirectory": "public",
  "framework": null,
  "functions": {
    "api/**/*.js": {
      "includeFiles": "backend/src/**"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
