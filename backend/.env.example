# Шаблон переменных окружения для backend.
# На сервере скопируй в backend/.env и заполни значениями из Vercel
# (Vercel → проект → Settings → Environment Variables).
#
#   cp backend/.env.example backend/.env && nano backend/.env

NODE_ENV=production
PORT=3001

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Auth ---
# ВАЖНО: возьми ТОТ ЖЕ JWT_SECRET, что стоит в Vercel.
# Иначе токены уже залогиненных пользователей станут невалидны и все
# вынуждены будут заново входить по PIN.
JWT_SECRET=

# Телефоны админов через запятую, формат 7XXXXXXXXXX
ADMIN_PHONE=

# --- Яндекс (серверный REST-геокодер) ---
YANDEX_API_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Необязательно: ограничить, кто из админов получает Telegram-алерты
# (цифры телефонов через запятую; пусто = все админы)
ALERT_ADMIN_PHONES=

# Публичный адрес сайта — нужен для deep-link Telegram-бота
PUBLIC_URL=https://taxioptimizer.ru
